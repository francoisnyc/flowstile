{
  "name": "@flowstile/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "typeorm migration:generate -d src/config/database.ts",
    "db:migrate": "typeorm migration:run -d src/config/database.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@temporalio/client": "^1.16.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@swc/core": "^1.15.30",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
