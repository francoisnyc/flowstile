# ── General ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=flowstile
DATABASE_USER=flowstile
DATABASE_PASSWORD=flowstile

# JWT secret for HTTP-only cookie auth (min 32 chars, change in production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Optional: Temporal server address
# Enables workflow signal on task completion. Omit to run without Temporal.
TEMPORAL_ADDRESS=localhost:7233

# ── Worker ────────────────────────────────────────────────────────────────
# URL the worker uses to call the Flowstile server REST API
FLOWSTILE_SERVER_URL=http://localhost:3000

# Temporal task queue (must match the queue your workflows target)
TASK_QUEUE=flowstile
