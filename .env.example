# Flowstile environment reference. Copy to .env for local dev. For production
# guidance (secrets, migrations, first-run) see docs/self-hosting.md.

# ── General ───────────────────────────────────────────────────────────────
# development | production. In production: schema sync is OFF (migrations are
# applied on boot), cookies are marked Secure (serve over HTTPS), and several
# dev fallbacks are disabled (a real JWT_SECRET and FLOWSTILE_API_KEY required).
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# PostgreSQL connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=flowstile
DATABASE_USER=flowstile
DATABASE_PASSWORD=flowstile          # CHANGE in production

# JWT secret for cookie/bearer auth. REQUIRED — the server refuses to boot
# without it. Use a long random value in production, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Temporal server address. Enables workflow signal delivery on task completion.
# Omit to run the inbox without Temporal (no workflow integration).
TEMPORAL_ADDRESS=localhost:7233

# Comma-separated allowed CORS origins (for a browser UI on another origin).
# Unset = same-origin only. Required for cross-origin cookie auth + CSRF.
# CORS_ORIGINS=https://app.example.com

# First-run admin bootstrap (used by `pnpm db:bootstrap`, NOT the server).
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# ADMIN_DISPLAY_NAME=Administrator

# ── Attachments ───────────────────────────────────────────────────────────
# local (default; on-disk) or s3.
ATTACHMENT_STORE=local
# ATTACHMENT_LOCAL_PATH=./.attachments
# ATTACHMENT_MAX_BYTES=10485760
# When ATTACHMENT_STORE=s3:
# ATTACHMENT_S3_BUCKET=
# ATTACHMENT_S3_REGION=
# ATTACHMENT_S3_PREFIX=attachments
# ATTACHMENT_S3_ACCESS_KEY_ID=        # omit to use the instance/role credentials
# ATTACHMENT_S3_SECRET_ACCESS_KEY=
# ATTACHMENT_S3_ENDPOINT=             # for S3-compatible stores (MinIO, R2, …)

# ── Background workers (server-internal; defaults are sensible) ────────────
# SIGNAL_RELAY_POLL_MS=2000           # how often the durable signal outbox drains
# ATTACHMENT_SWEEPER_POLL_MS=60000
# ATTACHMENT_ORPHAN_TTL_MS=86400000

# ── Temporal worker ───────────────────────────────────────────────────────
# URL the worker uses to call the Flowstile server REST API.
FLOWSTILE_SERVER_URL=http://localhost:3000

# Service API key the worker authenticates with. REQUIRED in production (create
# one via POST /auth/api-keys as an admin). In development a seeded dev key is
# used as a fallback.
# FLOWSTILE_API_KEY=fsk_...

# Temporal task queue (must match the queue your workflows target).
TASK_QUEUE=flowstile
